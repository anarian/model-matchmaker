{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "py hooks/session-init.py", "timeout": 2 }
    ],
    "beforeSubmitPrompt": [
      { "command": "py hooks/model-advisor.py", "timeout": 2 }
    ],
    "stop": [
      { "command": "py hooks/track-completion.py", "timeout": 2 }
    ]
  }
}
